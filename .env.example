# --- Modelo (LangChain / Anthropic) ---
# Clave para el modelo que orquesta el agente y los subagentes.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo por defecto (opcional). Si no se indica, se usa el de deepagents.
BOE_AGENT_MODEL=claude-sonnet-4-6

# --- Conexión al servidor boe-mcp (stdio) ---
# Comando que lanza tu servidor MCP del BOE. Dos formas habituales:
#   1) El console-script instalado:           boe-mcp
#   2) Ejecutar el módulo desde su repo:       python  (con args -m boe_mcp.server)
# Por defecto se usa el console-script "boe-mcp".
BOE_MCP_COMMAND=boe-mcp
# Argumentos separados por espacios (opcional). Ej. para la forma 2:
#   BOE_MCP_COMMAND=python
#   BOE_MCP_ARGS=-m boe_mcp.server
BOE_MCP_ARGS=
# Directorio de trabajo desde el que arrancar boe-mcp (opcional).
# Útil si lanzas "python -m boe_mcp.server" y necesitas su repo en el PATH.
BOE_MCP_CWD=
